# Environment Configuration Template
# Copy to .env and update values for your deployment

# === API Server Configuration ===
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False
API_RELOAD=True

# === Logging Configuration ===
LOG_LEVEL=INFO
LOG_FILE=logs/api.log
LOG_FORMAT=json

# === Storage Paths ===
MODELS_PATH=models
DATA_PATH=data

# === Model Training Configuration ===
DEFAULT_NUM_EPISODES=100
DEFAULT_NUM_TRAINING_PAIRS=20
DEFAULT_BATCH_SIZE=32
REPLAY_BUFFER_SIZE=10000

# === GNN Configuration ===
GNN_INPUT_DIM=1
GNN_HIDDEN_DIM=64
GNN_OUTPUT_DIM=32

# === DQN Configuration ===
DQN_LEARNING_RATE=0.001
DQN_GAMMA=0.99
DQN_EPSILON_INIT=1.0
DQN_EPSILON_DECAY=0.995
DQN_EPSILON_MIN=0.01

# === GPU/Hardware Configuration ===
CUDA_VISIBLE_DEVICES=0
USE_GPU=True
NUM_WORKERS=4

# === Security Configuration ===
ALLOW_ORIGINS=["http://localhost:3000", "http://localhost:8501"]
API_KEY_REQUIRED=False
API_KEY=your-secret-key-here

# === Database Configuration (if using external DB)
DB_URL=postgresql://user:password@localhost:5432/routing_db
DB_ECHO=False

# === Monitoring Configuration ===
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# === Dashboard Configuration ===
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_THEME_MODE=light

# === AWS Configuration (if deploying to AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=routing-system-models

# === Performance Tuning ===
REQUEST_TIMEOUT=300
TRAINING_TIMEOUT=600
MAX_NETWORK_NODES=500
MIN_NETWORK_NODES=5
